<Window x:Class="Praca_Inżynierska_v1.MVVM.View.ProductsList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Height="600" Width="1000"
        ResizeMode="NoResize"
        Background="#EAF4FF"
        WindowStyle="None">

    <Grid MouseDown="DragWindow">
        <!-- Pasek tytułowy -->
        <Grid Background="#1F468F" Height="40" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Lista Towarów"
                       FontSize="15"
                       FontFamily="Candara"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       Foreground="White" />

            <Button Name="MinimazeButton"
                    Grid.Column="1"
                    Margin="12"
                    BorderBrush="Yellow"
                    Click="MinimazeButton_Click">
                <Button.Background>
                    <ImageBrush ImageSource="/Button Images/minimize.png"/>
                </Button.Background>
            </Button>

            <Button Name="MaximizeButton"
                    Grid.Column="2"
                    Margin="12"
                    BorderBrush="Green"
                    Click="MaximizeButton_Click">
                <Button.Background>
                    <ImageBrush ImageSource="/Button Images/maximize.png"/>
                </Button.Background>
            </Button>

            <Button Name="CloseButton"
                    Grid.Column="3"
                    Margin="12"
                    BorderBrush="Red"
                    Click="CloseButton_Click">
                <Button.Background>
                    <ImageBrush ImageSource="/Button Images/close.png"/>
                </Button.Background>
            </Button>
        </Grid>

        <!-- Zawartość -->
        <Grid Margin="0,40,0,0">
            <StackPanel Margin="20">
                <TextBlock Text="Lista Towarów"
                           FontSize="30"
                           FontFamily="Candara"
                           HorizontalAlignment="Center"
                           Margin="0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Width="200"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,10,0"/>
                    <Button Content="Wyszukaj"
                            Command="{Binding SearchCommand}"
                            Width="100"/>
                </StackPanel>

                <DataGrid x:Name="ProductDataGrid"
                          ItemsSource="{Binding FilteredProducts}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F0F8FF"
                          GridLinesVisibility="Horizontal"
                          FontFamily="Arial"
                          FontSize="14"
                          Margin="0,0,0,10"
                          ColumnWidth="*"
                          CanUserResizeColumns="False"
                          CanUserReorderColumns="False">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="300"/>
                        <DataGridTextColumn Header="Cena" Binding="{Binding Price}" Width="100"/>
                        <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Jednostka" Binding="{Binding Unit}" Width="100"/>
                        <DataGridTextColumn Header="Rabat (%)" Binding="{Binding Discount}" Width="100"/>
                        <DataGridTextColumn Header="Data od" Binding="{Binding DiscountStartDate, StringFormat=d}" Width="120"/>
                        <DataGridTextColumn Header="Data do" Binding="{Binding DiscountEndDate, StringFormat=d}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Przycisk widoczny tylko dla kierownika -->
                <Button x:Name="SetDiscountButton"
                        Content="Ustal rabat"
                        Width="150"
                        Height="35"
                        FontFamily="Arial"
                        Background="#1F468F"
                        Foreground="White"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,10"
                        Click="SetDiscountButton_Click"
                        Visibility="Collapsed"/>

                <!-- Przycisk widoczny tylko dla kierownika -->
                <Button x:Name="RemoveDiscountButton"
                        Content="Usuń rabat"
                        Width="150"
                        Height="35"
                        FontFamily="Arial"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,0"
                        Click="RemoveDiscountButton_Click"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
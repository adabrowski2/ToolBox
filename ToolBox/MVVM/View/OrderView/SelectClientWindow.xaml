<Window x:Class="Praca_Inżynierska_v1.MVVM.View.SelectClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybierz klienta"
        WindowStartupLocation="CenterScreen"
        Height="600" Width="1000"
        ResizeMode="NoResize"
        Background="#EAF4FF"
        WindowStyle="None">

    <!-- Obramowanie-->
    <Border BorderBrush="#1F468F" BorderThickness="2" CornerRadius="5">
        <Grid>
            <!-- Pasek tytułowy -->
            <Grid Background="#1F468F" Height="40" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Wybierz klienta"
                           FontSize="15"
                           FontFamily="Candara"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           Foreground="White" />
            </Grid>

            <!-- Główna zawartość -->
            <StackPanel Margin="20,60,20,20">
                <TextBlock Text="Szukaj klienta"
                           FontSize="20"
                           FontFamily="Candara"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />

                <TextBox Width="300"
                         FontFamily="Candara"
                         FontSize="14"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"
                         HorizontalAlignment="Center"
                         VerticalContentAlignment="Center"/>

                <DataGrid ItemsSource="{Binding FilteredClients}"
                          SelectedItem="{Binding SelectedClient}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F0F8FF"
                          FontFamily="Arial"
                          FontSize="14"
                          Margin="0,10,0,10"
                          Height="370"
                          CanUserResizeColumns="False"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="Horizontal"
                          ColumnWidth="*">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ClientId}" Width="60" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="Typ" Binding="{Binding ClientType}" Width="120"/>
                        <DataGridTextColumn Header="Imię i nazwisko" Binding="{Binding FullName}" Width="200"/>
                        <DataGridTextColumn Header="Firma" Binding="{Binding CompanyName}" Width="200"/>
                        <DataGridTextColumn Header="Adres" Binding="{Binding Address}" Width="200"/>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Wybierz" Width="120" Margin="5" Command="{Binding ConfirmCommand}"/>
                    <Button Content="Wróć" Width="120" Margin="5" Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
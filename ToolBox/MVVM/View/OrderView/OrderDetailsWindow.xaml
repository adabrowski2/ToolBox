<Window x:Class="Praca_Inżynierska_v1.MVVM.View.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szczegóły zamówienia"
        Width="800" Height="500"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#EAF4FF"
        WindowStartupLocation="CenterScreen">

    <Border BorderBrush="#1F468F" BorderThickness="2" CornerRadius="5" Padding="0" Background="#EAF4FF">
        <Grid>

            <!-- Pasek tytułowy -->
            <Grid Background="#1F468F" Height="30" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Szczegóły zamówienia"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           FontSize="14"
                           FontFamily="Candara" />  
            </Grid>

            <!-- Główna zawartość -->
            <StackPanel Margin="20,40,20,20">
                <TextBlock Text="{Binding OrderHeader}"
                           FontSize="18"
                           FontWeight="Bold"
                           FontFamily="Candara"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <DataGrid ItemsSource="{Binding OrderItems}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F0F8FF"
                          FontFamily="Arial"
                          FontSize="14"
                          Height="300"
                          ColumnWidth="*"
                          CanUserResizeColumns="False"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produkt" Binding="{Binding ProductName}" Width="*" />
                        <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="100"/>
                        <DataGridTextColumn Header="Cena" Binding="{Binding UnitPrice}" Width="100"/>
                        <DataGridTextColumn Header="Rabat" Binding="{Binding Discount}" Width="100"/>
                        <DataGridTextColumn Header="Suma" Binding="{Binding TotalPrice}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Zamknij"
                        HorizontalAlignment="Right"
                        Width="100"
                        Margin="0,20,0,0"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
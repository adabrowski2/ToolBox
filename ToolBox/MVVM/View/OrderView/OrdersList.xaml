<Window x:Class="Praca_Inżynierska_v1.MVVM.View.OrdersList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Height="700" Width="1000"
        ResizeMode="NoResize"
        Background="#EAF4FF"
        WindowStyle="None">
    
    

    <Grid MouseDown="DragWindow">

        <!-- Pasek tytułowy -->
        <Grid Background="#1F468F" Height="40" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Lista Zamówień"
                       FontSize="15"
                       FontFamily="Candara"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       Foreground="White" />

            <!-- Minimalizacja -->
            <Button Name="MinimazeButton"
                    Grid.Column="1"
                    Margin="12"
                    BorderBrush="Yellow"
                    Click="MinimazeButton_Click">
                <Button.Background>
                    <ImageBrush ImageSource="/Button Images/minimize.png"/>
                </Button.Background>
            </Button>

            <!-- Maksymalizacja -->
            <Button Name="MaximizeButton"
                    Grid.Column="2"
                    Margin="12"
                    BorderBrush="Green"
                    Click="MaximizeButton_Click">
                <Button.Background>
                    <ImageBrush ImageSource="/Button Images/maximize.png"/>
                </Button.Background>
            </Button>

            <!-- Zamknięcie -->
            <Button Name="CloseButton"
                    Grid.Column="3"
                    Margin="12"
                    BorderBrush="Red"
                    Click="CloseButton_Click">
                <Button.Background>
                    <ImageBrush ImageSource="/Button Images/close.png"/>
                </Button.Background>
            </Button>
        </Grid>

        <!-- Główna zawartość -->
        <Grid Margin="0,40,0,0">
            <StackPanel Margin="20">

                <TextBlock Text="Zamówienia"
                           FontSize="30"
                           FontFamily="Candara"
                           HorizontalAlignment="Center"
                           Margin="0,10"/>

                <!-- Wyszukiwarka -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Width="200"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,10,0"/>
                    <Button Content="Wyszukaj"
                            Command="{Binding SearchCommand}"
                            Width="100"/>
                </StackPanel>

                <!-- Lista zamówień -->
                <DataGrid ItemsSource="{Binding FilteredOrders}"
                          SelectedItem="{Binding SelectedOrder}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F0F8FF"
                          FontFamily="Arial"
                          FontSize="14"
                          Margin="0,0,0,10"
                          ColumnWidth="*"
                          CanUserResizeColumns="False"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numer" Binding="{Binding OrderNumber}" Width="200"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding OrderDate}" Width="200"/>
                        <DataGridTextColumn Header="Klient" Binding="{Binding ClientName}" Width="200"/>
                        <DataGridTextColumn Header="Użytkownik" Binding="{Binding UserName}" Width="150"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Uwagi" Binding="{Binding Notes}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Przyciski -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Podejmij zamówienie"
                            Width="140"
                            Margin="5"
                            Click="AssignOrderButton_Click"
                            Visibility="{Binding IsMagazynier, Converter={StaticResource VisibilityConverter}}"/>

                    <Button Content="Zakończ zamówienie"
                            Width="140"
                            Margin="5"
                            Click="CompleteOrderButton_Click"
                            Visibility="{Binding IsMagazynier, Converter={StaticResource VisibilityConverter}}"/>
                    <Button Content="Szczegóły" Width="120" Margin="5" Click="DetailsButton_Click"/>
                    <Button Content="Dodaj zamówienie" Width="120" Margin="5" Click="AddOrderButton_Click" 
                            Visibility="{Binding IsMagazynier, Converter={StaticResource VisibilityConverter}, ConverterParameter=invert}"/>
                    <Button Content="Cofnij zamówienie" Width="120" Margin="5" Click="CancelOrderButton_Click"
                            Visibility="{Binding IsMagazynier, Converter={StaticResource VisibilityConverter}, ConverterParameter=invert}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
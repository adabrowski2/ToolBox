<Window x:Class="Praca_Inżynierska_v1.MVVM.View.SelectProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybierz produkt"
        WindowStartupLocation="CenterScreen"
        Height="500" Width="800"
        ResizeMode="NoResize"
        Background="#EAF4FF"
        WindowStyle="None">

    <Border BorderBrush="#1F468F" BorderThickness="2" CornerRadius="5">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Pasek tytułowy -->
            <Grid Background="#1F468F" Height="40" VerticalAlignment="Top">
                <TextBlock Text="Wybierz produkt"
                           FontSize="15"
                           FontFamily="Candara"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           Foreground="White" />
            </Grid>

            <!-- Główna zawartość -->
            <StackPanel Grid.Row="1" Margin="0,10,0,10">
                <TextBox Width="300"
                         FontFamily="Candara"
                         FontSize="14"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"
                         HorizontalAlignment="Left"
                         VerticalContentAlignment="Center"/>

                <DataGrid ItemsSource="{Binding FilteredProducts}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F0F8FF"
                          FontFamily="Arial"
                          FontSize="14"
                          Height="300"
                          CanUserResizeColumns="False"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="Horizontal"
                          ColumnWidth="*">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Cena" Binding="{Binding Price}" Width="100"/>
                        <DataGridTextColumn Header="Ilość dostępna" Binding="{Binding Quantity}" Width="120"/>
                        <DataGridTextColumn Header="Jednostka" Binding="{Binding Unit}" Width="100"/>
                        <DataGridTextColumn Header="Rabat (%)" Binding="{Binding Discount}" Width="100"/>
                        <DataGridTextColumn Header="Data od" Binding="{Binding DiscountStartDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                        <DataGridTextColumn Header="Data do" Binding="{Binding DiscountEndDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- Przyciski -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Zatwierdź" Width="120" Margin="5" Command="{Binding ConfirmCommand}"/>
                <Button Content="Anuluj" Width="120" Margin="5" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
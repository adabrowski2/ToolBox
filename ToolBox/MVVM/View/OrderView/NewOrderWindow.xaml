<Window x:Class="Praca_Inżynierska_v1.MVVM.View.NewOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:helpers="clr-namespace:Praca_Inżynierska_v1.Helpers"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Height="700" Width="1000"
        ResizeMode="NoResize"
        Background="#EAF4FF"
        WindowStyle="None">

    <Grid>
        <!-- Pasek tytułowy -->
        <Grid Background="#1F468F" Height="40" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Tworzenie nowego zamówienia"
                       FontSize="15"
                       FontFamily="Candara"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       Foreground="White" />
        </Grid>

        <!-- Główna zawartość -->
        <Grid Margin="0,40,0,0">
            <StackPanel Margin="20">

                <!-- Klient -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Klient:" Width="100" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedClient.FullName, Mode=OneWay}" 
                             IsReadOnly="True"
                             Width="300"
                             FontFamily="Candara"
                             FontSize="14"
                             Margin="0,0,10,0"/>
                    <Button Content="Wybierz klienta"
                            Width="150"
                            Command="{Binding SelectClientCommand}"/>
                </StackPanel>

                <!-- Produkty -->
                <DataGrid ItemsSource="{Binding OrderItems}"
                          SelectedItem="{Binding SelectedOrderItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          Height="300"
                          IsReadOnly="False"
                          AlternatingRowBackground="#F0F8FF"
                          FontFamily="Arial"
                          FontSize="14"
                          Margin="0,10,0,10"
                          ColumnWidth="*"
                          CanUserResizeColumns="False"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produkt" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Jednostka" Binding="{Binding Unit}" Width="100" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Ilość" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Quantity, StringFormat=N2}" HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding QuantityRaw, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalContentAlignment="Center" FontSize="14" Padding="2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Stan" Binding="{Binding StockQuantity}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Cena (suma)" Binding="{Binding TotalPrice, StringFormat=N2}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Rabat (%)" Binding="{Binding Discount}" Width="100"/>
                        <DataGridTextColumn Header="Od" Binding="{Binding DiscountStartDate, StringFormat=\{0:yyyy-MM-dd\}, TargetNullValue=''}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Do" Binding="{Binding DiscountEndDate, StringFormat=\{0:yyyy-MM-dd\}, TargetNullValue=''}" Width="100" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Przyciski -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="Dodaj pozycję" Width="150" Margin="0,0,10,0" Command="{Binding AddItemCommand}"/>
                    <Button Content="Usuń pozycję" Width="150" Command="{Binding RemoveItemCommand}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Zapisz" Width="120" Margin="5" Command="{Binding SaveOrderCommand}"/>
                    <Button Content="Anuluj" Width="120" Margin="5" Click="CancelButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
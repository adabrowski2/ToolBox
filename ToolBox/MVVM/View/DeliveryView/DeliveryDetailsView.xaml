<Window x:Class="Praca_Inżynierska_v1.MVVM.View.DeliveryDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Height="500" Width="700"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#EAF4FF"
        FontFamily="Arial">

    <Grid>
        <Grid Background="#1F468F" Height="40" VerticalAlignment="Top">
            <TextBlock Text="Szczegóły dostawy"
                       FontSize="15"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       Foreground="White"/>
        </Grid>

        <Grid Margin="0,40,0,0">
            <StackPanel Margin="20">
                <TextBlock Text="{Binding Delivery.OrderDate, StringFormat=Data zamówienia: {0:d}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Delivery.Status, StringFormat=Status: {0}}" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Delivery.ReceivedDate, StringFormat=Data przyjęcia: {0:d}}" 
                           Margin="0,0,0,15"
                           Visibility="{Binding Delivery.ReceivedDate}"/>

                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Margin="0,0,0,10"
                          Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produkt" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Zamówiono" Binding="{Binding Quantity}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Przyjęto" Binding="{Binding ReceivedQuantity, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Przyjmij"
                            HorizontalAlignment="Center"
                            Width="120"
                            Margin="5"
                            Background="#1F468F"
                            Foreground="White"
                            Command="{Binding AcceptDeliveryCommand}" />
                    <Button Content="Wróć"
                            HorizontalAlignment="Center"
                            Width="120"
                            Margin="5"
                            Command="{Binding CancelCommand}" />
                    
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
<Window x:Class="Praca_Inżynierska_v1.MVVM.View.MyMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyMessageBox"
        WindowStyle="None" 
        ResizeMode="NoResize"
        Width="400" 
        SizeToContent="Height"
        Background="#EAF4FF"
        WindowStartupLocation="CenterScreen">

    <Border BorderBrush="#1F468F" BorderThickness="2" CornerRadius="5">
        <Grid>
            <!-- Pasek tytułowy -->
            <Border Background="#1F468F" Height="30" VerticalAlignment="Top">
                <TextBlock x:Name="TitleTextBlock"
                           Text="Tytuł"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="White"/>
            </Border>

            <!-- Ikona + treść -->
            <StackPanel Orientation="Horizontal" Margin="20,40,20,60" HorizontalAlignment="Stretch">
                <Image x:Name="IconImage" Width="32" Height="32" Margin="0,0,10,0"/>
                <TextBlock x:Name="MessageTextBlock" 
                           Text="Treść komunikatu"
                           TextWrapping="Wrap"
                           FontSize="14"
                           VerticalAlignment="Top"
                           MaxWidth="320"/>
            </StackPanel>

            <!-- Przyciski -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,10">
                <Button x:Name="BtnOK" Content="OK" Width="80" Margin="5" Click="BtnOK_Click"/>
                <Button x:Name="BtnCancel" Content="Anuluj" Width="80" Margin="5" Click="BtnCancel_Click"/>
                <Button x:Name="BtnYes" Content="Tak" Width="80" Margin="5" Click="BtnYes_Click"/>
                <Button x:Name="BtnNo" Content="Nie" Width="80" Margin="5" Click="BtnNo_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
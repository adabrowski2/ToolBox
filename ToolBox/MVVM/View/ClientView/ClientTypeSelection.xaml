<Window x:Class="Praca_Inżynierska_v1.MVVM.View.ClientTypeSelection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="200" Width="400"
        Background="#EAF4FF">
    <Border BorderBrush="#1F468F" BorderThickness="2" CornerRadius="5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <TextBlock Text="Wybierz typ klienta:" FontSize="18" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Osoba fizyczna" Width="120" Margin="10" Click="PersonButton_Click"/>
                <Button Content="JDG" Width="120" Margin="10" Click="CompanyButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
<Window x:Class="Praca_Inżynierska_v1.MVVM.View.ClientDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Praca_Inżynierska_v1.Helpers"
        WindowStartupLocation="CenterScreen"
        Height="600" Width="500"
        ResizeMode="NoResize"
        Background="#EAF4FF"
        WindowStyle="None">

    <Window.Resources>
        <local:CompanyVisibilityConverter x:Key="CompanyVisibilityConverter"/>
    </Window.Resources>

    <!-- Obramowanie-->
    <Border BorderBrush="#1F468F" BorderThickness="2" CornerRadius="5">
        <Grid>

            <!-- Pasek górny -->
            <Grid Background="#1F468F" Height="40" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           FontSize="15"
                           FontFamily="Candara"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="10,0"
                           Foreground="White" />
            </Grid>

            <!-- Główna zawartość -->
            <Grid Margin="0,40,0,0">
                <StackPanel Margin="20">

                    <TextBlock
                               FontSize="30"
                               FontFamily="Candara"
                               HorizontalAlignment="Center"
                               Margin="0,10"><Run Language="pl-pl" Text="Szczegóły"/></TextBlock>

                    <!-- Pola edyccji -->
                    <TextBlock Text="Imię:"/>
                    <TextBox  x:Name="FirstNameTextBox" Text="{Binding FirstName}" Margin="0,0,0,10"/>

                    <TextBlock Text="Nazwisko:"/>
                    <TextBox  x:Name="LastNameTextBox" Text="{Binding LastName}" Margin="0,0,0,10"/>

                    <TextBlock Text="Email:"/>
                    <TextBox  x:Name="EmailTextBox" Text="{Binding Email}" Margin="0,0,0,10"/>

                    <TextBlock Text="Telefon:"/>
                    <TextBox x:Name="PhoneTextBox" Text="{Binding Phone}" Margin="0,0,0,10"/>

                    <!-- Adres - widoczne zawsze -->
                    <TextBlock Text="Adres:"/>
                    <TextBox  x:Name="AddressTextBox" Text="{Binding Address}" Margin="0,0,0,10"/>

                    <!-- Dodatkowe pola dla firm -->
                    <StackPanel Visibility="{Binding ClientType, Converter={StaticResource CompanyVisibilityConverter}}">
                        <TextBlock Text="Nazwa firmy:"/>
                        <TextBox x:Name="CompanyNameTextBox" Text="{Binding CompanyName}" Margin="0,0,0,10"/>

                        <TextBlock Text="NIP:"/>
                        <TextBox x:Name="NIPTextBox" Text="{Binding NIP}" Margin="0,0,0,10"/>

                        <TextBlock Text="REGON:"/>
                        <TextBox x:Name="REGONTextBox" Text="{Binding REGON}" Margin="0,0,0,10"/>
                    </StackPanel>

                    <!-- Przyciski -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button x:Name="SaveButton" Content="Zapisz" Width="100" Margin="5" Click="SaveButton_Click"/>
                        <Button x:Name="CancelButton" Content="Anuluj" Width="100" Margin="5" Click="CancelButton_Click"/>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>